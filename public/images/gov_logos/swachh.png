<script>
const trigger = document.querySelector('.accessibility');
const popup = document.querySelector('.access-type');
const container = document.querySelector('.user_accessibility');
const lastItem = document.querySelector('.tool-item a.scr-reader');
const closeBtn = document.querySelector('.close-accessbility');

if (trigger) {

  const openMenu = () => {
    trigger.classList.add('expand');
    trigger.setAttribute('aria-expanded', 'true');
  };

  const closeMenu = () => {
    trigger.classList.remove('expand');
    trigger.setAttribute('aria-expanded', 'false');
  };

  // Open on focus
  trigger.addEventListener('focus', openMenu);

  // Close when tabbing out from last item
  if (lastItem) {
    lastItem.addEventListener('blur', closeMenu);
  }

  // Close when using close button
  if (closeBtn) {
    // Mouse click
    closeBtn.addEventListener('click', closeMenu);

    // Keyboard - Enter
    closeBtn.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        closeMenu();
      }
    });

    // Keyboard - Space
    closeBtn.addEventListener('keyup', (e) => {
      if (e.key === ' ' || e.key === 'Spacebar') {
        e.preventDefault();
        closeMenu();
      }
    });
  }
}
</script>


