<script>
let currentSize = 100; // default 100%

const announcer = document.getElementById("fontAnnouncement");

function updateFont() {
    document.body.style.fontSize = currentSize + "%";

    // Announce change
    announcer.textContent = "Text size increased to " + currentSize + " percent";
}

// Increase
document.getElementById("increasetext1").addEventListener("click", function () {
    if (currentSize < 120) { // limit
        currentSize += 10;
        updateFont();
    }
});

// Decrease
document.getElementById("decreasetext").addEventListener("click", function () {
    if (currentSize > 80) {
        currentSize -= 10;
        document.body.style.fontSize = currentSize + "%";
        announcer.textContent = "Text size decreased to " + currentSize + " percent";
    }
});

// Reset
document.getElementById("resettext").addEventListener("click", function () {
    currentSize = 100;
    document.body.style.fontSize = "100%";
    announcer.textContent = "Text size reset to 100 percent";
});
</script>




<script type="text/javascript">
