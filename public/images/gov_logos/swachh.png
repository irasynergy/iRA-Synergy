</script>
<script>
(function () {

  function fixPager() {
    const pagers = document.querySelectorAll("nav.pager");

    pagers.forEach(function (pager) {
      if (pager.getAttribute("role") === "navigation") {
        pager.removeAttribute("role");
      }

      pager.setAttribute("aria-label", "Pagination");
    });
  }

  // Run on load
  document.addEventListener("DOMContentLoaded", fixPager);

  // Watch for DOM changes (AJAX updates)
  const observer = new MutationObserver(function () {
    fixPager();
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true
  });

})();
</script>


