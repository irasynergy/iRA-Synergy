<!-----   accessability font size change js code start  ---->
  <script>
let curSize = 16;       // default font size
let increaseCount = 0;  // track max 2 clicks

const selector = '.wrappers, p, a, h1, h2, h3, h4, h5, h6, .govlogo, nav span, .ticker, .news marquee, nav a';

// Increase (max 2 times)
$('#increasetext1').click(function () {
    if (increaseCount < 2) {
        curSize = parseInt($(selector).css('font-size')) + 1;

        if (curSize <= 18) {
            $(selector).css('font-size', curSize + 'px');
            increaseCount++;
        }
    }
});

// Reset
$('#resettext').click(function () {
    curSize = 16;
    increaseCount = 0;

    $(selector).css('font-size', '16px');
});

// Decrease
$('#decreasetext').click(function () {
    curSize = parseInt($(selector).css('font-size')) - 1;

    if (curSize >= 12) {
        $(selector).css('font-size', curSize + 'px');
        increaseCount--; // allow increasing again
    }
});
</script>
 
