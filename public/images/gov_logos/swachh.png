<script>
'use strict';

function Carousel(node) {
  this.node = node;
  this.items = node.querySelectorAll('.carousel-item');
  this.liveRegion = node.querySelector('.carousel-items');

  this.playBtn = node.querySelector('.rotation');
  this.prevBtn = node.querySelector('.previous');
  this.nextBtn = node.querySelector('.next');

  this.index = 0;
  this.interval = 3000;
  this.playing = true;
  this.timer = null;

  this.show(this.index, false);
  this.updatePlayState();
  this.start();

  this.playBtn.addEventListener('click', () => this.toggle());
  this.prevBtn.addEventListener('click', () => this.userPrev());
  this.nextBtn.addEventListener('click', () => this.userNext());
}

/* ---------- DISPLAY ---------- */

Carousel.prototype.show = function(i, announce) {
  if (announce) {
    this.liveRegion.setAttribute('aria-live', 'polite');
  } else {
    this.liveRegion.removeAttribute('aria-live');
  }

  this.items.forEach((item, idx) => {
    const active = idx === i;
    item.classList.toggle('active', active);
    item.setAttribute('aria-hidden', active ? 'false' : 'true');
  });
};

/* ---------- AUTOPLAY ---------- */

Carousel.prototype.start = function() {
  this.stop();

  if (!this.playing || this.items.length <= 1) return;

  this.timer = setInterval(() => {
    this.index = (this.index + 1) % this.items.length;
    this.show(this.index, false);
  }, this.interval);
};

Carousel.prototype.stop = function() {
  if (this.timer) {
    clearInterval(this.timer);
    this.timer = null;
  }
};

/* ---------- USER CONTROLS ---------- */

Carousel.prototype.userNext = function() {
  this.index = (this.index + 1) % this.items.length;
  this.show(this.index, true);
};

Carousel.prototype.userPrev = function() {
  this.index = (this.index - 1 + this.items.length) % this.items.length;
  this.show(this.index, true);
};

Carousel.prototype.toggle = function() {
  this.playing = !this.playing;
  this.updatePlayState();

  // Announce current slide
  this.show(this.index, true);

  if (this.playing) {
    this.start();
  } else {
    this.stop();
  }
};

/* ---------- PLAY / PAUSE UI ---------- */

Carousel.prototype.updatePlayState = function() {
  if (this.playing) {
    this.playBtn.classList.add('play');
    this.playBtn.classList.remove('pause');
    this.playBtn.setAttribute('aria-label', 'Stop automatic slide show');
  } else {
    this.playBtn.classList.add('pause');
    this.playBtn.classList.remove('play');
    this.playBtn.setAttribute('aria-label', 'Start automatic slide show');
  }
};

/* ---------- INIT ---------- */

window.addEventListener('load', () => {
  document.querySelectorAll('.carousel')
    .forEach(carousel => new Carousel(carousel));
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const tabs = document.querySelectorAll(".tablinks");

  tabs.forEach(tab => {

    // Click support
    tab.addEventListener("click", function (e) {
      setActiveTab(this);
    });

    // Keyboard support (Enter + Space)
    tab.addEventListener("keydown", function (e) {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        this.click(); // trigger click
      }
    });

  });

  function setActiveTab(activeTab) {
    tabs.forEach(tab => tab.classList.remove("active"));
    activeTab.classList.add("active");
  }
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {

    const button = document.querySelector(".marquee-toggle");
    const marquee = document.querySelector(".views-view-marquee marquee");

    let isPaused = false;

    // Button control
    button.addEventListener("click", function () {
        isPaused = !isPaused;

        if (isPaused) {
            marquee.stop();
            button.setAttribute("aria-pressed", "true");
            button.setAttribute("aria-label", "Play");
            button.innerHTML = '<i class="fa fa-play"></i>';
        } else {
            marquee.start();
            button.setAttribute("aria-pressed", "false");
            button.setAttribute("aria-label", "Pause");
            button.innerHTML = '<i class="fa fa-pause"></i>';
        }
    });

    // Hover behavior (ONLY if not manually paused)
    marquee.addEventListener("mouseover", function () {
        if (!isPaused) {
            marquee.stop();
        }
    });

    marquee.addEventListener("mouseout", function () {
        if (!isPaused) {
            marquee.start();
        }
    });

});
</script>
